STRIPE_PRICE_STARTER=price_1ThY9w377xE4C0OxJPby2yLm
# Growth   ($25/mo)  prod_Ugw3ojhxZz8UIk
STRIPE_PRICE_GROWTH=price_1ThYB0377xE4C0OxvXVHgURT
# Pro      ($60/mo)  prod_Ugw4zRN2wt3Vcm  (app plan id: professional)
STRIPE_PRICE_PROFESSIONAL=price_1ThYCX377xE4C0Oxxt8xpB26
# Business ($150/mo) prod_Uh7RHpcVAtFi1L
STRIPE_PRICE_BUSINESS=price_1ThjC9377xE4C0Ox7EbgD06I
