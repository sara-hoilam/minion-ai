SECRET_KEY=change-me-in-production

# Local dev (default)
# DATABASE_URL=sqlite:///minion.db

# Supabase Postgres (MinionAI-DB) — Minion AI uses Flask + SQLAlchemy (not Prisma)
SUPABASE_URL=https://icqipnezzvsqxmjgeonx.supabase.co
SUPABASE_PROJECT_REF=icqipnezzvsqxmjgeonx

# Recommended for Flask (persistent server): Session pooler, port 5432
# App auto-uses pg8000 driver (no psycopg2 build required on Python 3.14 / ARM Windows)
DATABASE_URL=postgresql://postgres.icqipnezzvsqxmjgeonx:[YOUR-PASSWORD]@aws-1-us-west-2.pooler.supabase.com:5432/postgres

# Optional: Transaction pooler (port 6543) — Supabase shows this for Prisma/serverless
# DATABASE_URL=postgresql://postgres.icqipnezzvsqxmjgeonx:[YOUR-PASSWORD]@aws-1-us-west-2.pooler.supabase.com:6543/postgres

# Optional: Session pooler for one-off migrations/scripts (Prisma calls this DIRECT_URL)
# DATABASE_DIRECT_URL=postgresql://postgres.icqipnezzvsqxmjgeonx:[YOUR-PASSWORD]@aws-1-us-west-2.pooler.supabase.com:5432/postgres

# Supabase Storage (project context files — required for file upload)
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=
SUPABASE_STORAGE_BUCKET=project-context

# Public URL of the app (password reset emails redirect here)
APP_URL=http://localhost:5000

ANTHROPIC_API_KEY=
# Cursor API (Composer 2.5)
CURSOR_API_KEY=
CURSOR_MODEL=composer-2.5
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
